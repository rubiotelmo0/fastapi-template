meta {
  name: Create item
  type: http
  seq: 1
}

post {
  url: {{baseURL}}/items
  body: json
  auth: inherit
}

body:json {
  {
    "name": "starter-item",
    "description": "First item created from the Bruno collection.",
    "is_active": true
  }
}

vars:post-response {
  itemId: res('id')
}

assert {
  res.status: eq 201
  res.body.id: isNumber
  res.body.name: eq starter-item
  res.body.is_active: eq true
}

settings {
  encodeUrl: true
}
