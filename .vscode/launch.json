{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Hypercorn (FastAPI) — run from fastapi_app/",
            "type": "python",
            "request": "launch",
            "module": "hypercorn",
            "args": [
                "--reload",
                "--bind",
                "0.0.0.0:8000",
                "app.main:app"
            ],
            "cwd": "${workspaceFolder}/fastapi_app",
            "envFile": "${workspaceFolder}/.env",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/fastapi_app"
            },
            "justMyCode": false,
            "console": "integratedTerminal",
            "jinja": true
        }
    ]
}